# docker/build_biomnibench_runtime_image.sh uses harbor_agent/ as build context.
# biomnibench-da-runtime.Dockerfile has no COPY steps; exclude local datasets and
# dev trees so "docker build" does not upload multi-GB trees to the daemon.

.git
.gitignore
.dockerignore
.venv
.DS_Store

data/
results/

docs/
tests/
example/
configs/
scripts/
custom_agents/
custom_envs/

**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache

*.md
*.log
