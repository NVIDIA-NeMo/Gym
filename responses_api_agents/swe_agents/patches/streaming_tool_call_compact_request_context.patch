+@pytest.mark.asyncio
+async def test_compact_streaming_request_sends_context_once(monkeypatch):
+    client = NemoGymClient.__new__(NemoGymClient)
+    client.ng_server_client = MagicMock()
+    client.ng_server_client.post = AsyncMock()
+    client.ng_server_client.global_config_dict = OmegaConf.create(
+        {
+            "policy_model": {
+                "responses_api_models": {
+                    "vllm_model": {"host": "model-host", "port": 1234}
+                }
+            }
+        }
+    )
+    client.model_server_cookies = {"session": "sticky"}
+    http_session = MagicMock()
+    response = MagicMock()
+    response.cookies = {"session": "sticky"}
+    http_session.post = AsyncMock(return_value=response)
+    monkeypatch.setattr(client_module, "raise_for_status", AsyncMock())
+    monkeypatch.setattr(
+        client_module,
+        "get_response_json",
+        AsyncMock(return_value={"sequence_no": 0}),
+    )
+    monkeypatch.setenv("NEMO_GYM_MODEL_SERVER_NAME", "policy_model")
+    context = StreamingToolCallContext(
+        client=client,
+        response_id="response",
+        tool_call_id="call",
+        function_name="execute_bash",
+        chat_completion={
+            "messages": [
+                {"role": "user", "content": "fix it"},
+                {
+                    "role": "assistant",
+                    "content": "",
+                    "tool_calls": [],
+                    "prompt_token_ids": [1, 2],
+                    "generation_token_ids": [3],
+                    "generation_log_probs": [-0.1],
+                },
+            ],
+            "tools": [],
+        },
+        config={
+            "enabled": True,
+            "exact_incremental_tokenizer": True,
+            "compact_request_context": True,
+            "max_sessions": 256,
+            "session_ttl_seconds": 900,
+        },
+    )
+
+    await client.streaming_tool_call_request(
+        action="tokenize",
+        session_id="session",
+        context=context,
+        sequence_no=0,
+        tool_output="first bucket",
+        prefill=True,
+        prefill_continuation=True,
+        http_session=http_session,
+    )
+    initial_call = http_session.post.await_args
+    initial_request = _streaming_request_json(initial_call)
+    initial_request_bytes = len(initial_call.kwargs["data"])
+    assert initial_request["compact_context"] is True
+    assert initial_request["max_contexts"] == 256
+    assert initial_request["context_ttl_seconds"] == 900
+    assert initial_request["chat_completion"]["messages"][-1]["content"] == (
+        "first bucket"
+    )
+
+    result = await client.streaming_tool_call_request(
+        action="tokenize",
+        session_id="session",
+        context=context,
+        sequence_no=1,
+        tool_output="first bucket plus more output",
+        prefill=True,
+        prefill_continuation=True,
+        http_session=http_session,
+    )
+    compact_call = http_session.post.await_args
+    compact_request = _streaming_request_json(compact_call)
+    assert compact_request == {
+        "session_id": "session",
+        "exact_incremental_tokenizer": True,
+        "compact_context": True,
+        "tool_output": "first bucket plus more output",
+        "sequence_no": 1,
+        "prefill": True,
+        "prefill_continuation": True,
+    }
+    assert len(compact_call.kwargs["data"]) < initial_request_bytes
+    assert result["client_compact_context_requests"] == 1
+
+
