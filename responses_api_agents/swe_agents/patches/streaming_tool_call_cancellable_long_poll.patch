+    session = BashSession.__new__(BashSession)
+    session._stream_condition = threading.Condition()
+    session._stream_revision = 0
+    session._stream_content = ""
+    session._stream_id = None
+
+    async def is_disconnected():
+        return False
+
+    waiter = asyncio.create_task(
+        session.wait_for_stream_snapshot_async(
