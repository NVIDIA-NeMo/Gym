+    async def wait_for_stream_snapshot_async(
+        self,
+        *,
+        stream_id: str,
+        min_content_chars: int,
+        timeout_seconds: float,
+        is_disconnected: Callable[[], Awaitable[bool]],
+        poll_interval_seconds: float = 0.05,
+    ) -> dict[str, int | str | None]:
+        """Wait for a snapshot without occupying an executor thread."""
+        if min_content_chars < 0:
+            raise ValueError("minimum snapshot characters must be non-negative")
+        if timeout_seconds < 0:
+            raise ValueError("snapshot wait timeout must be non-negative")
+        if poll_interval_seconds <= 0:
+            raise ValueError("snapshot poll interval must be positive")
+
+        deadline = time.monotonic() + timeout_seconds
+        while True:
+            snapshot = self.get_stream_snapshot()
+            content = snapshot["content"]
+            if (
+                snapshot["stream_id"] == stream_id
+                and isinstance(content, str)
+                and len(content) >= min_content_chars
+            ):
+                return snapshot
+            if await is_disconnected():
+                raise asyncio.CancelledError
+            remaining_seconds = deadline - time.monotonic()
+            if remaining_seconds <= 0:
+                return snapshot
+            await asyncio.sleep(min(poll_interval_seconds, remaining_seconds))
+
     def _reset_stream_snapshot(self, stream_id: str | None) -> None:
         with self._stream_condition:
             self._stream_revision += 1
