+            min_content_chars=128,
+            timeout_seconds=1,
+            is_disconnected=is_disconnected,
+            poll_interval_seconds=0.001,
+        )
+    )
+    await asyncio.sleep(0)
+    session._reset_stream_snapshot("current-command")
+    with session._stream_condition:
