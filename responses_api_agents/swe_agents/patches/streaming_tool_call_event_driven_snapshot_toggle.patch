diff --git a/tests/unit/runtime/utils/test_bash_session.py b/tests/unit/runtime/utils/test_bash_session.py
--- a/tests/unit/runtime/utils/test_bash_session.py
+++ b/tests/unit/runtime/utils/test_bash_session.py
@@ -141,6 +141,40 @@
         )
 
 
+@pytest.mark.asyncio
+async def test_async_stream_snapshot_wait_can_use_polling_fallback():
+    session = BashSession.__new__(BashSession)
+    session._stream_condition = threading.Condition()
+    session._stream_revision = 0
+    session._stream_content = ""
+    session._stream_id = "current-command"
+
+    async def is_disconnected():
+        return False
+
+    waiter = asyncio.create_task(
+        session.wait_for_stream_snapshot_async(
+            stream_id="current-command",
+            min_content_chars=128,
+            timeout_seconds=1,
+            is_disconnected=is_disconnected,
+            poll_interval_seconds=0.001,
+            event_driven_snapshot_wait=False,
+        )
+    )
+    await asyncio.sleep(0)
+    with session._stream_condition:
+        session._stream_content = "x" * 128
+        session._stream_revision += 1
+
+    assert await waiter == {
+        "revision": 1,
+        "content": "x" * 128,
+        "stream_id": "current-command",
+    }
+    assert not hasattr(session, "_stream_async_waiters")
+
+
 def test_cwd_property(tmp_path):
