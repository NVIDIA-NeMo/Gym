@@ -1,5 +1,6 @@
 import os
 import tempfile
+import threading
 import time
 
 from openhands.core.logger import openhands_logger as logger
@@ -34,6 +35,52 @@ def test_session_initialization():
     session.close()
 
 
+def test_wait_for_stream_snapshot_requires_matching_stream_and_target():
+    session = BashSession.__new__(BashSession)
+    session._stream_condition = threading.Condition()
+    session._stream_revision = 0
+    session._stream_content = ""
+    session._stream_id = None
+    result = {}
+    wait_started = threading.Event()
+
+    def wait_for_snapshot():
+        wait_started.set()
+        result.update(
+            session.wait_for_stream_snapshot(
+                stream_id="current-command",
+                min_content_chars=128,
+                timeout_seconds=1,
+            )
+        )
+
+    waiter = threading.Thread(target=wait_for_snapshot)
+    waiter.start()
+    assert wait_started.wait(timeout=1)
+
+    with session._stream_condition:
+        session._stream_id = "previous-command"
+        session._stream_content = "x" * 256
+        session._stream_revision += 1
+        session._stream_condition.notify_all()
+    time.sleep(0.01)
+    assert waiter.is_alive()
+
+    session._reset_stream_snapshot("current-command")
+    with session._stream_condition:
+        session._stream_content = "x" * 128
+        session._stream_revision += 1
+        session._stream_condition.notify_all()
+
+    waiter.join(timeout=1)
+    assert not waiter.is_alive()
+    assert result == {
+        "revision": 3,
+        "content": "x" * 128,
+        "stream_id": "current-command",
+    }
+
+
 def test_cwd_property(tmp_path):
     session = BashSession(work_dir=tmp_path)
     session.initialize()
