+def _update_action_timing_metrics(
+    action: Action,
+    request_seconds: float,
+    server_seconds: float,
+) -> None:
+    """Record low-overhead action timing when detailed diagnostics are enabled."""
+    if os.getenv('OPENHANDS_DETAILED_RUNTIME_METRICS') != '1':
+        return
+    metrics_path = os.getenv('NEMO_GYM_METRICS_FPATH')
+    if not metrics_path:
+        return
+
+    phase = os.getenv('OPENHANDS_METRICS_PHASE', 'unknown')
+    phase_prefixes = {
+        'runtime_setup': 'openhands_runtime_setup',
+        'runtime_initialize': 'openhands_runtime_initialize',
+        'controller': 'openhands_controller',
+        'runtime_completion': 'openhands_runtime_completion',
+    }
+    increments: dict[str, int | float] = {
+        'openhands_action_request_count': 1,
+        'openhands_action_request_seconds': request_seconds,
+        'openhands_action_server_seconds': server_seconds,
+    }
+    phase_prefix = phase_prefixes.get(phase)
+    if phase_prefix is not None:
+        increments[f'{phase_prefix}_action_count'] = 1
+        increments[f'{phase_prefix}_action_request_seconds'] = request_seconds
+        increments[f'{phase_prefix}_action_server_seconds'] = server_seconds
+    if phase == 'controller' and isinstance(
+        action, (CmdRunAction, Terminus2CmdRunAction)
+    ):
+        increments['openhands_controller_cmd_action_count'] = 1
+        increments['openhands_controller_cmd_action_request_seconds'] = (
+            request_seconds
+        )
+        increments['openhands_controller_cmd_action_server_seconds'] = (
+            server_seconds
+        )
+
+    try:
+        with open(metrics_path) as metrics_file:
+            metrics = json.load(metrics_file)
+        for key, increment in increments.items():
+            metrics[key] = metrics.get(key, 0) + increment
+        with open(metrics_path, 'w') as metrics_file:
+            json.dump(metrics, metrics_file)
+    except (FileNotFoundError, json.JSONDecodeError, OSError):
+        pass
+
+
