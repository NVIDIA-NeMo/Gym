+def _streaming_tool_call_observation_text(
+    observation: Observation,
+    max_message_chars: int | None,
+) -> str:
+    """Match the command observation text added by ConversationMemory."""
+    if isinstance(observation, CmdOutputObservation):
+        return truncate_content(
+            observation.to_agent_observation(), max_message_chars
+        )
+    if isinstance(observation, ErrorObservation):
+        content = truncate_content(observation.content, max_message_chars)
+        return f"{content}\n[Error occurred in processing last action]"
+    raise TypeError(
+        "streaming command execution returned unsupported observation "
+        f"{type(observation).__name__}"
+    )
+
