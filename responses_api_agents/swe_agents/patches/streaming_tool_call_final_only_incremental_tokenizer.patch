+    @pytest.mark.asyncio
+    async def test_execute_action_final_only_tokenizer_needs_no_snapshots(self):
+        runtime = LocalRuntime.__new__(LocalRuntime)
+        runtime.api_url = "http://runtime"
+        runtime.sid = "runtime-session"
+        release_post = threading.Event()
+        session = MagicMock()
+        runtime.session = session
+        final_observation = CmdOutputObservation(
+            content="final command output",
+            command="echo output",
+            metadata=CmdOutputMetadata(
+                exit_code=0,
+                suffix="\n[The command completed with exit code 0.]",
+            ),
+        )
+        post_response = MagicMock()
+        post_response.json.return_value = event_to_dict(final_observation)
+
+        def post(*args, **kwargs):
+            assert release_post.wait(timeout=1)
+            return post_response
+
+        session.post.side_effect = post
+        streaming_client = MagicMock()
+        streaming_client.llm.config.max_message_chars = 1_000
+
+        async def tokenize_request(**kwargs):
+            assert kwargs["action"] == "tokenize"
+            if kwargs["sequence_no"] == 0:
+                release_post.set()
+            result = {
+                "sequence_no": kwargs["sequence_no"],
+                "token_count": 17,
+                "encoded_chars": 20 if kwargs["final"] else 0,
+                "encoded_tokens": 4 if kwargs["final"] else 0,
+                "reused_tokens": 13 if kwargs["final"] else 0,
+                "rollback_tokens": 2 if kwargs["final"] else 0,
+                "checkpoint_count": int(kwargs["sequence_no"] == 0),
+                "checkpoint_tokens": 13 if kwargs["sequence_no"] == 0 else 0,
+                "checkpoint_mismatches": 0,
+                "incremental_valid": True,
+            }
+            if kwargs["final"]:
+                result["reuse_id"] = "runtime-session:response:call"
+            return result
+
+        streaming_client.streaming_tool_call_request = AsyncMock(
+            side_effect=tokenize_request
+        )
+        context = StreamingToolCallContext(
+            client=streaming_client,
+            response_id="response",
+            tool_call_id="call",
+            function_name="execute_bash",
+            chat_completion={"messages": [], "tools": []},
+            config={
+                "enabled": True,
+                "tokenizer_only": True,
+                "exact_incremental_tokenizer": True,
+                "final_only_incremental_tokenizer": True,
+                "min_chunk_chars": 256,
+                "snapshot_poll_interval_seconds": 0.05,
+                "flush_interval_seconds": 0.25,
+                "request_timeout_seconds": 5,
+            },
+        )
+        _STREAMING_TOOL_CALL_CONTEXTS["response"] = context
+        action = CmdRunAction(command="echo output")
+        action.tool_call_metadata = ToolCallMetadata(
+            model_response=ModelResponse(id="response", choices=[]),
+            total_calls_in_response=1,
+        )
+        action.response_id = "response"
+
+        with (
+            patch(
+                "openhands.runtime.impl.local.local_runtime.get_global_config_dict",
+                return_value={"streaming_tool_call": {"enabled": True}},
+            ),
+            patch(
+                "openhands.runtime.impl.local.local_runtime._update_streaming_tool_call_metrics"
+            ) as update_metrics,
+        ):
+            response = runtime._send_action_server_request(
+                "POST",
+                "http://runtime/execute_action",
+                json={"action": event_to_dict(action)},
+                timeout=5,
+            )
+
+        assert response is post_response
+        session.get.assert_not_called()
+        requests = streaming_client.streaming_tool_call_request.await_args_list
+        assert [request.kwargs["action"] for request in requests] == [
+            "tokenize",
+            "tokenize",
+        ]
+        assert [request.kwargs["sequence_no"] for request in requests] == [0, 1]
+        assert [request.kwargs["tool_output"] for request in requests] == [
+            "",
+            final_observation.to_agent_observation(),
+        ]
+        assert [request.kwargs["final"] for request in requests] == [False, True]
+        metrics = update_metrics.call_args_list[-1].args[0]
+        assert metrics["streaming_tool_call_snapshot_polls"] == 0
+        assert metrics["streaming_tool_call_tokenizer_only_actions"] == 1
+        assert metrics["streaming_tool_call_valid_tokenizer_actions"] == 1
+        assert metrics["streaming_tool_call_incremental_tokenizer_requests"] == 2
+        assert (
+            metrics[
+                "streaming_tool_call_final_only_incremental_tokenizer_actions"
+            ]
+            == 1
+        )
+        assert metrics[
+            "streaming_tool_call_valid_final_only_incremental_tokenizer_actions"
+        ] == 1
+        streaming_client.register_streaming_prompt_reuse.assert_called_once_with(
+            "runtime-session:response:call"
+        )
