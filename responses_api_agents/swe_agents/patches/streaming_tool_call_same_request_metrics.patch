+def test_streaming_same_request_model_call_attribution(
+    monkeypatch,
+    tmp_path,
+    same_request_status,
+    outcome,
+):
+    metrics_path = tmp_path / "metrics.json"
+    metrics_path.write_text("{}")
+    monkeypatch.setenv("NEMO_GYM_METRICS_FPATH", str(metrics_path))
+
+    NemoGymClient._update_streaming_prompt_reuse_metrics(
+        "matched",
+        "exact",
+        same_request_status=same_request_status,
+        latency=2.5,
+        prefill_reused_tokens=64,
+        prefill_attempted=True,
+        prompt_tokens=100,
+        completion_tokens=5,
+        cached_prompt_tokens=80,
+        required_prefix_tokens=64,
+    )
+
+    metrics = orjson.loads(metrics_path.read_bytes())
+    assert metrics["streaming_tool_call_same_request_attempts"] == 1
+    assert metrics[
+        f"streaming_tool_call_same_request_status_{same_request_status}"
+    ] == 1
+    assert metrics[
+        f"streaming_tool_call_same_request_{outcome}_model_call_count"
+    ] == 1
+    assert metrics[
+        f"streaming_tool_call_same_request_{outcome}_model_call_seconds"
+    ] == 2.5
