diff --git a/tests/unit/runtime/impl/test_local_runtime.py b/tests/unit/runtime/impl/test_local_runtime.py
--- a/tests/unit/runtime/impl/test_local_runtime.py
+++ b/tests/unit/runtime/impl/test_local_runtime.py
@@ -430,6 +430,114 @@ class TestLocalRuntime:
             == final_observation.to_agent_observation()
         )
 
+    @pytest.mark.asyncio
+    async def test_execute_action_incrementally_tokenizes_without_prefill(self):
+        runtime = LocalRuntime.__new__(LocalRuntime)
+        runtime.api_url = "http://runtime"
+        runtime.sid = "runtime-session"
+        release_post = threading.Event()
+        session = MagicMock()
+        runtime.session = session
+        final_observation = CmdOutputObservation(
+            content="partial output final",
+            command="echo output",
+            metadata=CmdOutputMetadata(
+                exit_code=0,
+                suffix="\n[The command completed with exit code 0.]",
+            ),
+        )
+        post_response = MagicMock()
+        post_response.json.return_value = event_to_dict(final_observation)
+
+        def post(*args, **kwargs):
+            assert release_post.wait(timeout=1)
+            return post_response
+
+        snapshots = [
+            {"revision": 1, "content": "partial"},
+            {"revision": 2, "content": "partial output"},
+        ]
+        snapshot_index = 0
+
+        def get(*args, **kwargs):
+            nonlocal snapshot_index
+            snapshot = snapshots[min(snapshot_index, len(snapshots) - 1)]
+            snapshot_index += 1
+            response = MagicMock()
+            response.json.return_value = snapshot
+            return response
+
+        session.post.side_effect = post
+        session.get.side_effect = get
+        streaming_client = MagicMock()
+
+        async def tokenize_request(**kwargs):
+            assert kwargs["action"] == "tokenize"
+            if kwargs["sequence_no"] == 1:
+                release_post.set()
+            return {"sequence_no": kwargs["sequence_no"], "token_count": 17}
+
+        streaming_client.streaming_tool_call_request = AsyncMock(
+            side_effect=tokenize_request
+        )
+        context = StreamingToolCallContext(
+            client=streaming_client,
+            response_id="response",
+            tool_call_id="call",
+            function_name="execute_bash",
+            chat_completion={"messages": [], "tools": []},
+            config={
+                "enabled": True,
+                "tokenizer_only": True,
+                "min_chunk_chars": 10,
+                "snapshot_poll_interval_seconds": 0.001,
+                "flush_interval_seconds": 0.001,
+                "request_timeout_seconds": 5,
+            },
+        )
+        _STREAMING_TOOL_CALL_CONTEXTS["response"] = context
+        action = CmdRunAction(command="echo output")
+        action.tool_call_metadata = ToolCallMetadata(
+            model_response=ModelResponse(id="response", choices=[]),
+            total_calls_in_response=1,
+        )
+        action.response_id = "response"
+        serialized_action = event_to_dict(action)
+
+        with (
+            patch(
+                "openhands.runtime.impl.local.local_runtime.get_global_config_dict",
+                return_value={"streaming_tool_call": {"enabled": True}},
+            ),
+            patch(
+                "openhands.runtime.impl.local.local_runtime._update_streaming_tool_call_metrics"
+            ) as update_metrics,
+        ):
+            response = runtime._send_action_server_request(
+                "POST",
+                "http://runtime/execute_action",
+                json={"action": serialized_action},
+                timeout=5,
+            )
+
+        assert response is post_response
+        actions = [
+            call.kwargs["action"]
+            for call in streaming_client.streaming_tool_call_request.await_args_list
+        ]
+        assert actions == ["tokenize", "tokenize"]
+        assert all(
+            action not in {"start", "append", "close", "abort"}
+            for action in actions
+        )
+        metrics = update_metrics.call_args_list[-1].args[0]
+        assert metrics["streaming_tool_call_sessions_started"] == 0
+        assert metrics["streaming_tool_call_prefill_requests"] == 0
+        assert metrics["streaming_tool_call_prefill_tokens"] == 0
+        assert metrics["streaming_tool_call_tokenizer_only_actions"] == 1
+        assert metrics["streaming_tool_call_incremental_tokenizer_requests"] == 2
+        assert metrics["streaming_tool_call_incremental_tokenizer_tokens"] == 34
+
     def test_execute_action_skips_streaming_for_short_completed_output(self):
         runtime = LocalRuntime.__new__(LocalRuntime)
         runtime.api_url = "http://runtime"
