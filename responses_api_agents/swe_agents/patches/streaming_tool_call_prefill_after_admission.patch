     @pytest.mark.asyncio
+    async def test_execute_action_prefills_bucket_after_admission(self):
+        runtime = LocalRuntime.__new__(LocalRuntime)
+        runtime.api_url = "http://runtime"
+        runtime.sid = "runtime-session"
+        release_post = threading.Event()
+        session = MagicMock()
+        runtime.session = session
+        first_streamed_content = "x" * 300
+        second_streamed_content = "x" * 600
+        snapshot_responses = []
+        for revision, content in enumerate(
+            (first_streamed_content, second_streamed_content), start=1
+        ):
+            snapshot_response = MagicMock()
+            snapshot_response.json.return_value = {
+                "revision": revision,
+                "content": content,
+            }
+            snapshot_responses.append(snapshot_response)
+        snapshot_index = 0
+
+        def get_snapshot(*args, **kwargs):
+            nonlocal snapshot_index
+            response = snapshot_responses[min(snapshot_index, 1)]
+            snapshot_index += 1
+            return response
+
+        session.get.side_effect = get_snapshot
+        final_observation = CmdOutputObservation(
+            content=f"{second_streamed_content} done",
+            command="produce output",
+            metadata=CmdOutputMetadata(
+                exit_code=0,
+                suffix="\n[The command completed with exit code 0.]",
+            ),
+        )
+        post_response = MagicMock()
+        post_response.json.return_value = event_to_dict(final_observation)
+
+        def post(*args, **kwargs):
+            assert release_post.wait(timeout=1)
+            return post_response
+
+        session.post.side_effect = post
+        streaming_client = MagicMock()
+        streaming_client.llm.config.max_message_chars = 1_000
+
+        async def tokenize_request(**kwargs):
+            sequence_no = kwargs["sequence_no"]
+            if sequence_no == 1:
+                request_tokens = 13
+            elif sequence_no == 2:
+                request_tokens = 20
+            else:
+                request_tokens = 0
+            result = {
+                "sequence_no": sequence_no,
+                "token_count": 40,
+                "encoded_chars": 300 if sequence_no > 0 else 0,
+                "encoded_tokens": 20 if sequence_no > 0 else 0,
+                "reused_tokens": 33 if kwargs["final"] else 0,
+                "rollback_tokens": 0,
+                "checkpoint_count": 0,
+                "checkpoint_tokens": 0,
+                "checkpoint_mismatches": 0,
+                "incremental_valid": True,
+                "prefill_sessions_started": int(sequence_no == 0),
+                "prefill_requests": int(sequence_no in (1, 2)),
+                "prefill_control_plane_requests": 0,
+                "prefill_tokens": request_tokens,
+                "prefill_completed_chunks": int(sequence_no in (1, 2)),
+                "prefill_dummy_tokens": int(sequence_no in (1, 2)),
+                "prefill_prefix_matched": kwargs["final"],
+                "prefill_failures": 0,
+                "prefill_seconds": 0.01,
+                "prefix_seed_attempts": int(sequence_no == 0),
+                "prefix_seed_successes": int(sequence_no == 0),
+                "prefix_seed_fallbacks": 0,
+                "prefix_seed_seconds": 0.01 if sequence_no == 0 else 0.0,
+            }
+            if sequence_no == 2:
+                release_post.set()
+            if kwargs["final"]:
+                result["reuse_id"] = "runtime-session:response:call"
+            return result
+
+        streaming_client.streaming_tool_call_request = AsyncMock(
+            side_effect=tokenize_request
+        )
+        context = StreamingToolCallContext(
+            client=streaming_client,
+            response_id="response",
+            tool_call_id="call",
+            function_name="execute_bash",
+            chat_completion={"messages": [], "tools": []},
+            config={
+                "enabled": True,
+                "tokenizer_only": True,
+                "exact_incremental_tokenizer": True,
+                "final_only_incremental_tokenizer": True,
+                "final_only_prefill": True,
+                "prefill_after_admission": True,
+                "final_only_prefill_completion_grace_seconds": 0.0,
+                "min_chunk_chars": 256,
+                "snapshot_poll_interval_seconds": 0.001,
+                "flush_interval_seconds": 0.25,
+                "request_timeout_seconds": 5,
+            },
+        )
+        _STREAMING_TOOL_CALL_CONTEXTS["response"] = context
+        action = CmdRunAction(command="produce output")
+        action.tool_call_metadata = ToolCallMetadata(
+            model_response=ModelResponse(id="response", choices=[]),
+            total_calls_in_response=1,
+        )
+        action.response_id = "response"
+
+        with (
+            patch(
+                "openhands.runtime.impl.local.local_runtime.get_global_config_dict",
+                return_value={"streaming_tool_call": {"enabled": True}},
+            ),
+            patch(
+                "openhands.runtime.impl.local.local_runtime._update_streaming_tool_call_metrics"
+            ) as update_metrics,
+        ):
+            response = runtime._send_action_server_request(
+                "POST",
+                "http://runtime/execute_action",
+                json={"action": event_to_dict(action)},
+                timeout=5,
+            )
+
+        assert response is post_response
+        assert session.get.call_count >= 2
+        requests = streaming_client.streaming_tool_call_request.await_args_list
+        assert [request.kwargs["sequence_no"] for request in requests] == [
+            0,
+            1,
+            2,
+            3,
+        ]
+        assert [request.kwargs["tool_output"] for request in requests[:3]] == [
+            "",
+            first_streamed_content,
+            second_streamed_content,
+        ]
+        assert [request.kwargs["final"] for request in requests] == [
+            False,
+            False,
+            False,
+            True,
+        ]
+        assert all(request.kwargs["prefill"] for request in requests)
+        assert all(
+            request.kwargs["prefill_continuation"] for request in requests
+        )
+        metrics = update_metrics.call_args_list[-1].args[0]
+        assert metrics["streaming_tool_call_prefill_after_admission_actions"] == 1
+        assert (
+            metrics[
+                "streaming_tool_call_valid_prefill_after_admission_actions"
+            ]
+            == 1
+        )
+        assert metrics["streaming_tool_call_prefill_after_admission_requests"] == 2
+        assert metrics["streaming_tool_call_prefill_after_admission_tokens"] == 33
+        assert (
+            metrics[
+                "streaming_tool_call_prefill_after_admission_request_seconds"
+            ]
+            > 0
+        )
+        assert metrics["streaming_tool_call_prefill_requests"] == 2
+        assert metrics["streaming_tool_call_prefill_tokens"] == 33
+        assert metrics["streaming_tool_call_completed_chunks"] == 2
+        assert metrics["streaming_tool_call_dummy_tokens"] == 2
+        assert metrics["streaming_tool_call_prefix_matches"] == 1
+        streaming_client.register_streaming_prompt_reuse.assert_called_once_with(
+            "runtime-session:response:call"
+        )
