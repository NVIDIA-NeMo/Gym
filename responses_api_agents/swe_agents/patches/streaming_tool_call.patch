+def test_stream_snapshot_is_revisioned_and_command_echo_is_removed():
+    session = BashSession(work_dir=os.getcwd())
+    session._closed = True
+    session._reset_stream_snapshot()
+    initial_snapshot = session.get_stream_snapshot()
+
+    session._update_stream_snapshot(
+        command="echo hello",
+        pane_content="echo hello\nhello",
+        ps1_matches=[],
+    )
+    updated_snapshot = session.get_stream_snapshot()
+    session._update_stream_snapshot(
+        command="echo hello",
+        pane_content="echo hello\nhello",
+        ps1_matches=[],
+    )
+
+    assert initial_snapshot["content"] == ""
+    assert updated_snapshot["content"] == "hello"
+    assert updated_snapshot["revision"] == initial_snapshot["revision"] + 1
+    assert session.get_stream_snapshot() == updated_snapshot
