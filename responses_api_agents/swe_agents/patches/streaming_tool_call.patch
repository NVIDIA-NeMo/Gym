+from unittest.mock import AsyncMock, MagicMock
+
+import pytest
+from omegaconf import OmegaConf
+
+from openhands.agenthub import nemo_gym_client as client_module
+from openhands.agenthub.nemo_gym_client import (
+    NemoGymClient,
+    StreamingToolCallContext,
+)
+
+
+@pytest.mark.asyncio
+async def test_streaming_request_uses_loop_local_session(monkeypatch):
+    client = NemoGymClient.__new__(NemoGymClient)
+    client.ng_server_client = MagicMock()
+    client.ng_server_client.post = AsyncMock()
+    client.ng_server_client.global_config_dict = OmegaConf.create(
+        {
+            "policy_model": {
+                "responses_api_models": {
+                    "vllm_model": {"host": "model-host", "port": 1234}
+                }
+            }
+        }
+    )
+    client.model_server_cookies = {"session": "sticky"}
+    http_session = MagicMock()
+    http_session.post = AsyncMock()
+    response = MagicMock()
+    response.cookies = {"session": "sticky"}
+    http_session.post.return_value = response
+    monkeypatch.setattr(client_module, "raise_for_status", AsyncMock())
+    monkeypatch.setattr(
+        client_module,
+        "get_response_json",
+        AsyncMock(return_value={"sequence_no": 0, "chunk_tokens": 0}),
+    )
+    monkeypatch.setenv("NEMO_GYM_MODEL_SERVER_NAME", "policy_model")
+    context = StreamingToolCallContext(
+        client=client,
+        response_id="response",
+        tool_call_id="call",
+        function_name="execute_bash",
+        chat_completion={
+            "messages": [
+                {"role": "user", "content": "fix it"},
+                {
+                    "role": "assistant",
+                    "content": None,
+                    "tool_calls": [],
+                    "prompt_token_ids": [1, 2],
+                    "generation_token_ids": [3],
+                    "generation_log_probs": [-0.1],
+                },
+            ],
+            "tools": [],
+        },
+        config={"enabled": True},
+    )
+
+    result = await client.streaming_tool_call_request(
+        action="start",
+        session_id="session",
+        context=context,
+        sequence_no=0,
+        tool_output="partial output",
+        http_session=http_session,
+    )
+
+    assert result == {"sequence_no": 0, "chunk_tokens": 0}
+    client.ng_server_client.post.assert_not_awaited()
+    request_call = http_session.post.await_args
+    assert request_call.args == (
+        "http://model-host:1234/v1/streaming_tool_call/start",
+    )
+    request = request_call.kwargs
+    assert request["cookies"] == {"session": "sticky"}
+    assert request["json"]["chat_completion"]["messages"][-1] == {
+        "role": "tool",
+        "content": "partial output",
+        "tool_call_id": "call",
+        "name": "execute_bash",
+    }
+    assert request["json"]["chat_completion"]["messages"][-2][
+        "generation_token_ids"
+    ] == [3]
